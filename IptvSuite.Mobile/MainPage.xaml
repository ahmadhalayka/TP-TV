<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:IptvSuite.Mobile"
    xmlns:components="clr-namespace:IptvSuite.Mobile.Components"
    x:Class="IptvSuite.Mobile.MainPage"
    Padding="{OnPlatform Android='0,24,0,16', iOS='0,44,0,34'}">

	<BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
		<BlazorWebView.RootComponents>

            <RootComponent Selector="#app"
               ComponentType="{x:Type components:BootTest}" />

        </BlazorWebView.RootComponents>
	</BlazorWebView>

</ContentPage>
